PORT=5001
DATABASE_URL=postgresql://user:password@localhost:5432/school_saas
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_secret
NODE_ENV=production
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://yourdomain.com
# Sentry DSN for error tracking (leave blank to disable)
SENTRY_DSN=
# Redis URL for background jobs and caching (leave blank to disable async jobs)
REDIS_URL=redis://localhost:6379
# Cloudflare R2 / S3 file storage (leave blank to disable file uploads)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=school-saas
R2_CDN_BASE=https://cdn.yourdomain.com
# Automated backups: daily pg_dump uploaded to R2 under the 'backups/' prefix.
# Also configure an R2/S3 lifecycle rule to expire 'backups/*' after this many days.
BACKUP_RETENTION_DAYS=7
# Audit log retention in days (logs older than this are purged monthly by auditPurgeWorker)
AUDIT_LOG_RETENTION_DAYS=730
